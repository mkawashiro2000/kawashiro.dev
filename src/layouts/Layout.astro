---
interface Props {
  title: string;
  description?: string;
  /** Ruta absoluta de la imagen social; por defecto la og-image general */
  ogImage?: string;
}

const {
  title,
  description = 'Full Stack (Back-end/Data) Developer. Data, analytics and web apps, served from a self-hosted Raspberry Pi in Constanza, Dominican Republic.',
  ogImage = '/og-image.webp',
} = Astro.props;

const SITE_URL = 'https://kawashiro.dev';
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;

// Datos estructurados: tarjeta de persona para buscadores
const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Mitsunori Kawashiro',
  url: SITE_URL,
  image: `${SITE_URL}/og-image.webp`,
  jobTitle: 'Full Stack (Back-end/Data) Developer',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Constanza',
    addressRegion: 'La Vega',
    addressCountry: 'DO',
  },
  email: 'mailto:mkawashiro01@gmail.com',
  sameAs: [
    'https://github.com/mkawashiro2000',
    'https://www.instagram.com/kawashiro.dev',
  ],
  knowsAbout: ['Python', 'TypeScript', 'Data Science', 'FastAPI', 'React', 'Docker', 'PostgreSQL'],
});

// Fuentes autoalojadas: sin llamadas a Google Fonts (privacidad + TTFB)
import '@fontsource-variable/fredoka';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    {/* SVG primero: nítido en cualquier densidad; PNG como respaldo */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#11111b" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* SEO + social link previews (WhatsApp, X, LinkedIn...) */}
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href={`${SITE_URL}/rss.xml`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mitsunori Kawashiro" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Datos estructurados (Person) para buscadores */}
    <script type="application/ld+json" set:html={personSchema} />

    {/* Script crítico de bloqueo: Sincroniza el DOM con Zustand localStorage antes del renderizado */}
    <script is:inline>
      (function() {
        try {
          // Tema: preferencia guardada o la del sistema, antes del primer paint
          const saved = localStorage.getItem('kawashiro-theme');
          const dark = saved === 'dark' || (saved !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark-theme');

          const storage = localStorage.getItem('kawashiro-dev-storage');
          if (storage) {
            const parsed = JSON.parse(storage);
            if (parsed?.state?.isProMode) {
              document.documentElement.classList.add('pro-theme');
            }
            const locale = parsed?.state?.locale;
            if (locale === 'en' || locale === 'es' || locale === 'ja') {
              document.documentElement.lang = locale;
            }
          }
        } catch (e) {
          console.error("Error inicializando la topología CSS:", e);
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <script src="/js/theme.js" defer></script>
  </body>
</html>
