---
import Layout from '../../layouts/Layout.astro';
import { Code } from 'astro:components';
import { translations } from '../../i18n/translations';
import { PYTHON_SOURCE } from './tokenizer-source';

const SOURCE_UI = {
  en: {
    title: 'The original script',
    intro: 'This tool is a faithful port of a Python CLI I wrote first: same suffix list, same order, same rules. The browser version just adds the colored pills.',
  },
  es: {
    title: 'El script original',
    intro: 'Esta herramienta es un port fiel de una CLI en Python que escribí primero: misma lista de sufijos, mismo orden, mismas reglas. La versión del navegador solo añade las píldoras de color.',
  },
  ja: {
    title: '元のスクリプト',
    intro: 'このツールは、最初に書いた Python の CLI を忠実に移植したものです:同じ接尾辞リスト、同じ順序、同じルール。ブラウザ版は色付きのピルを追加しただけです。',
  },
};

const i18nData = {
  en: { back: translations.en.tools.back, ...translations.en.tools.tokenizer, source: SOURCE_UI.en },
  es: { back: translations.es.tools.back, ...translations.es.tools.tokenizer, source: SOURCE_UI.es },
  ja: { back: translations.ja.tools.back, ...translations.ja.tools.tokenizer, source: SOURCE_UI.ja },
};
const t = i18nData.en;
---

<Layout title="Tokenizer & Lemmatizer | Mitsunori Kawashiro">
  <script type="application/json" id="i18n-data" set:html={JSON.stringify(i18nData)} />

  <main class="min-h-screen w-full" style="color: var(--color-green500);">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 py-16">
      <div class="flex items-center justify-between mb-2">
        <a href="/proyectos" data-i18n="back" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">{t.back}</a>
        <div class="lang-switcher">
          <button type="button" data-lang-btn="en" class="lang-pill">EN</button>
          <button type="button" data-lang-btn="es" class="lang-pill">ES</button>
          <button type="button" data-lang-btn="ja" class="lang-pill">JA</button>
        </div>
      </div>

      <h1 data-i18n="title" class="font-display font-semibold text-4xl sm:text-6xl tracking-tight mt-6 mb-4">
        {t.title}
      </h1>
      <p data-i18n="subtitle" class="text-lg opacity-70 mb-3 max-w-xl">
        {t.subtitle}
      </p>
      <p data-i18n="note" class="text-sm opacity-50 mb-10 max-w-xl">
        {t.note}
      </p>

      <textarea
        id="input"
        rows="6"
        data-i18n-placeholder="placeholder"
        placeholder={t.placeholder}
        class="w-full rounded-3xl p-6 text-base sm:text-lg font-sans resize-none outline-none"
        style="background: var(--color-bg-secondary); color: var(--color-green500); border: 1px solid rgba(0,0,0,0.08);"
      ></textarea>

      <div class="mt-10">
        <span data-i18n="tokensLabel" class="text-sm font-semibold uppercase tracking-widest opacity-70">{t.tokensLabel}</span>
        <div id="tokens" class="flex flex-wrap gap-2 mt-4"></div>
      </div>

      <div class="mt-10">
        <span data-i18n="lemmasLabel" class="text-sm font-semibold uppercase tracking-widest opacity-70">{t.lemmasLabel}</span>
        <div id="lemmas" class="flex flex-wrap gap-2 mt-4"></div>
      </div>

      {/* Código fuente original (la CLI en Python que inspiró la herramienta) */}
      <section class="mt-16">
        <h2 data-i18n="source.title" class="font-display text-2xl sm:text-3xl font-semibold mb-2">
          {t.source.title}
        </h2>
        <p data-i18n="source.intro" class="opacity-70 mb-5 max-w-2xl">{t.source.intro}</p>
        <div class="rounded-2xl overflow-hidden text-[0.82rem]">
          <Code code={PYTHON_SOURCE} lang="python" theme="github-dark" />
        </div>
      </section>
    </div>
  </main>

  <script src="/js/i18n.js" defer></script>
</Layout>

<script>
  const input = document.getElementById('input') as HTMLTextAreaElement;
  const tokensEl = document.getElementById('tokens')!;
  const lemmasEl = document.getElementById('lemmas')!;

  // Port fiel de NLPProcesadorEsp (Python) — ver el código original más abajo.
  // Orden importante: los sufijos largos van primero para que 'ábamos' gane
  // sobre 'amos' y 'iendo' sobre 'en'.
  const SUFIJOS = [
    'ábamos', 'áramos', 'iéramos', 'arían', 'erían', 'irían',
    'mente', 'ando', 'iendo', 'aron', 'eron', 'aban', 'arán', 'erán', 'irán',
    'amos', 'emos', 'imos', 'aba', 'ada', 'ida', 'ado', 'ido', 'ara', 'era',
    'iré', 'aré', 'ar', 'er', 'ir', 'an', 'en', 'as', 'es',
  ];

  function tokenize(text: string): string[] {
    // Equivalente a re.findall(r'\w+|[^\w\s]', texto): el \w de Python abarca
    // Unicode, así que aquí usamos clases \p{...} con el flag 'u'.
    return text.match(/[\p{L}\p{N}_]+|[^\p{L}\p{N}\s_]/gu) || [];
  }

  function lemmatize(word: string): string {
    let w = word.toLowerCase();

    // isalpha() + longitud mínima: números y signos quedan intactos
    if (!/^\p{L}+$/u.test(w) || w.length <= 3) return w;

    // Plural primero: 'es' antes que 's'
    if (w.endsWith('es') && w.length > 4) w = w.slice(0, -2);
    else if (w.endsWith('s') && w.length > 3) w = w.slice(0, -1);

    // Primer sufijo que deje una raíz de al menos 2 caracteres
    for (const suf of SUFIJOS) {
      if (w.endsWith(suf) && w.length - suf.length >= 2) {
        return w.slice(0, -suf.length);
      }
    }
    return w;
  }

  function pill(text: string, bg: string) {
    const span = document.createElement('span');
    span.textContent = text;
    span.className = 'text-sm font-medium rounded-full px-3.5 py-1.5';
    span.style.background = bg;
    return span;
  }

  function analyze() {
    const tokens = tokenize(input.value);
    tokensEl.innerHTML = '';
    lemmasEl.innerHTML = '';

    const colors = ['var(--color-mint)', 'var(--color-babyblue)', 'var(--color-lilac)', 'var(--color-yellow)'];
    tokens.forEach((t, i) => tokensEl.appendChild(pill(t, colors[i % colors.length])));

    const words = tokens.filter((t) => /^\p{L}+$/u.test(t));
    words.forEach((w, i) => lemmasEl.appendChild(pill(`${w} → ${lemmatize(w)}`, colors[i % colors.length])));
  }

  input.addEventListener('input', analyze);
</script>
