---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Detector de sentimientos | Mitsunori Kawashiro">
  <main class="min-h-screen w-full" style="color: var(--color-green500);">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 py-16">
      <a href="/" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">← Volver</a>

      <h1 class="font-display font-semibold text-4xl sm:text-6xl tracking-tight mt-6 mb-4">
        Detector de sentimientos
      </h1>
      <p class="text-lg opacity-70 mb-2 max-w-xl">
        Analiza la impresión general de un texto en español usando un léxico de palabras positivas y negativas.
      </p>
      <p class="text-sm opacity-50 mb-10 max-w-xl">
        El análisis corre en el backend (FastAPI) contra un diccionario de sentimiento, no en el navegador.
      </p>

      <textarea
        id="input"
        rows="6"
        placeholder="Escribe una opinión, reseña o comentario..."
        class="w-full rounded-3xl p-6 text-base sm:text-lg font-sans resize-none outline-none"
        style="background: var(--color-bg-secondary); color: var(--color-green500); border: 1px solid rgba(0,0,0,0.08);"
      ></textarea>

      <button
        id="analyze-btn"
        class="mt-6 rounded-full px-8 py-3 font-semibold transition-transform hover:scale-105"
        style="background: var(--color-green500); color: var(--color-beige);"
      >
        Analizar sentimiento
      </button>

      <p id="error-msg" class="mt-4 text-sm hidden" style="color: var(--color-rust);"></p>

      <div id="result" class="mt-10 hidden">
        <div id="verdict-card" class="rounded-3xl p-8 sm:p-10">
          <span class="text-sm font-semibold uppercase tracking-widest opacity-70">Resultado</span>
          <h2 id="verdict-text" class="font-display text-4xl sm:text-5xl font-semibold mt-2"></h2>
        </div>
        <div class="grid grid-cols-2 gap-4 mt-4">
          <div class="rounded-3xl p-6" style="background: var(--color-mint);">
            <p class="text-3xl font-display font-semibold">
              <span id="stat-pos">0</span>
              <span class="text-lg opacity-60">(<span id="stat-pos-pct">0</span>%)</span>
            </p>
            <p class="text-sm font-medium uppercase tracking-widest opacity-70 mt-1">Palabras positivas</p>
          </div>
          <div class="rounded-3xl p-6" style="background: var(--color-rust);">
            <p class="text-3xl font-display font-semibold">
              <span id="stat-neg">0</span>
              <span class="text-lg opacity-60">(<span id="stat-neg-pct">0</span>%)</span>
            </p>
            <p class="text-sm font-medium uppercase tracking-widest opacity-70 mt-1">Palabras negativas</p>
          </div>
        </div>
        <p class="text-sm opacity-50 mt-3">
          Porcentajes calculados sobre las <span id="stat-total">0</span> palabras con carga emocional detectadas (de <span id="stat-wordcount">0</span> palabras totales).
        </p>
        <div id="words-detail" class="flex flex-wrap gap-2 mt-4"></div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const input = document.getElementById('input') as HTMLTextAreaElement;
  const btn = document.getElementById('analyze-btn') as HTMLButtonElement;
  const result = document.getElementById('result')!;
  const errorMsg = document.getElementById('error-msg')!;
  const verdictCard = document.getElementById('verdict-card')!;
  const verdictText = document.getElementById('verdict-text')!;
  const statPos = document.getElementById('stat-pos')!;
  const statNeg = document.getElementById('stat-neg')!;
  const statPosPct = document.getElementById('stat-pos-pct')!;
  const statNegPct = document.getElementById('stat-neg-pct')!;
  const statTotal = document.getElementById('stat-total')!;
  const statWordcount = document.getElementById('stat-wordcount')!;
  const wordsDetail = document.getElementById('words-detail')!;

  function pill(text: string, bg: string) {
    const span = document.createElement('span');
    span.textContent = text;
    span.className = 'text-sm font-medium rounded-full px-3.5 py-1.5';
    span.style.background = bg;
    return span;
  }

  btn.addEventListener('click', async () => {
    const text = input.value.trim();
    if (!text) return;

    errorMsg.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Analizando...';

    try {
      const res = await fetch('/api/v1/sentiment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text }),
      });

      if (!res.ok) throw new Error(`API respondió ${res.status}`);
      const data = await res.json();

      statPos.textContent = String(data.positive_count);
      statNeg.textContent = String(data.negative_count);
      statPosPct.textContent = String(data.positive_percentage);
      statNegPct.textContent = String(data.negative_percentage);
      statTotal.textContent = String(data.sentiment_word_count);
      statWordcount.textContent = String(data.word_count);

      let verdict = 'Neutral';
      let bg = 'var(--color-babyblue)';
      if (data.verdict === 'positivo') { verdict = 'Positivo 🙂'; bg = 'var(--color-mint)'; }
      else if (data.verdict === 'negativo') { verdict = 'Negativo 🙁'; bg = 'var(--color-rust)'; }

      verdictText.textContent = verdict;
      verdictCard.setAttribute('style', `background: ${bg}`);

      wordsDetail.innerHTML = '';
      (data.positive_words as string[]).forEach((w) => wordsDetail.appendChild(pill(w, 'var(--color-mint)')));
      (data.negative_words as string[]).forEach((w) => wordsDetail.appendChild(pill(w, 'var(--color-rust)')));

      result.classList.remove('hidden');
    } catch (err) {
      errorMsg.textContent = 'No se pudo conectar con la API de análisis. Verifica que el backend esté activo.';
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Analizar sentimiento';
    }
  });
</script>
