---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';

const i18nData = {
  en: { back: translations.en.tools.back, ...translations.en.tools.wordCounter },
  es: { back: translations.es.tools.back, ...translations.es.tools.wordCounter },
  ja: { back: translations.ja.tools.back, ...translations.ja.tools.wordCounter },
};
const t = i18nData.en;
---

<Layout title="Word Counter | Mitsunori Kawashiro">
  <script type="application/json" id="i18n-data" set:html={JSON.stringify(i18nData)} />

  <main class="min-h-screen w-full" style="color: var(--color-green500);">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 py-16">
      <div class="flex items-center justify-between mb-2">
        <a href="/proyectos" data-i18n="back" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">{t.back}</a>
        <div class="lang-switcher">
          <button type="button" data-lang-btn="en" class="lang-pill">EN</button>
          <button type="button" data-lang-btn="es" class="lang-pill">ES</button>
          <button type="button" data-lang-btn="ja" class="lang-pill">JA</button>
        </div>
      </div>

      <h1 data-i18n="title" class="font-display font-semibold text-4xl sm:text-6xl tracking-tight mt-6 mb-4">
        {t.title}
      </h1>
      <p data-i18n="subtitle" class="text-lg opacity-70 mb-10 max-w-xl">
        {t.subtitle}
      </p>

      <textarea
        id="input"
        rows="8"
        data-i18n-placeholder="placeholder"
        placeholder={t.placeholder}
        class="w-full rounded-3xl p-6 text-base sm:text-lg font-sans resize-none outline-none focus:ring-2"
        style="background: var(--color-bg-secondary); color: var(--color-green500); border: 1px solid rgba(0,0,0,0.08);"
      ></textarea>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-8">
        <div class="rounded-3xl p-6" style="background: var(--color-mint);">
          <p class="text-3xl font-display font-semibold" id="stat-words">0</p>
          <p data-i18n="stats.words" class="text-sm font-medium uppercase tracking-widest opacity-70 mt-1">{t.stats.words}</p>
        </div>
        <div class="rounded-3xl p-6" style="background: var(--color-babyblue);">
          <p class="text-3xl font-display font-semibold" id="stat-chars">0</p>
          <p data-i18n="stats.chars" class="text-sm font-medium uppercase tracking-widest opacity-70 mt-1">{t.stats.chars}</p>
        </div>
        <div class="rounded-3xl p-6" style="background: var(--color-yellow);">
          <p class="text-3xl font-display font-semibold" id="stat-digits">0</p>
          <p data-i18n="stats.digits" class="text-sm font-medium uppercase tracking-widest opacity-70 mt-1">{t.stats.digits}</p>
        </div>
        <div class="rounded-3xl p-6" style="background: var(--color-rust);">
          <p class="text-3xl font-display font-semibold" id="stat-special">0</p>
          <p data-i18n="stats.special" class="text-sm font-medium uppercase tracking-widest opacity-70 mt-1">{t.stats.special}</p>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/i18n.js" defer></script>
</Layout>

<script>
  const input = document.getElementById('input') as HTMLTextAreaElement;
  const statWords = document.getElementById('stat-words')!;
  const statChars = document.getElementById('stat-chars')!;
  const statDigits = document.getElementById('stat-digits')!;
  const statSpecial = document.getElementById('stat-special')!;

  function analyze() {
    const text = input.value;
    const words = text.trim().length ? text.trim().split(/\s+/) : [];
    const digits = (text.match(/[0-9]/g) || []).length;
    const special = (text.match(/[^a-zA-ZÀ-ÿ0-9\s]/g) || []).length;

    statWords.textContent = String(words.length);
    statChars.textContent = String(text.length);
    statDigits.textContent = String(digits);
    statSpecial.textContent = String(special);
  }

  input.addEventListener('input', analyze);
  analyze();
</script>
