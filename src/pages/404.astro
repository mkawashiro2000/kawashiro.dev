---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found | Mitsunori Kawashiro" description="This route does not exist on the edge node.">
  <main id="main-content" class="min-h-[100dvh] flex items-center justify-center p-6" style="background-color:#11111b">
    <div
      class="w-full max-w-2xl rounded-xl overflow-hidden font-mono text-sm shadow-2xl"
      style="background-color:#1e1e2e; border:1px solid #313244"
    >
      <!-- Barra de título estilo macOS -->
      <div class="flex items-center px-4 py-2.5" style="background-color:#181825; border-bottom:1px solid #11111b">
        <div class="flex gap-2">
          <span class="w-3.5 h-3.5 rounded-full" style="background-color:#ff5f57"></span>
          <span class="w-3.5 h-3.5 rounded-full" style="background-color:#febc2e"></span>
          <span class="w-3.5 h-3.5 rounded-full" style="background-color:#28c840"></span>
        </div>
        <div class="flex-1 text-center text-xs" style="color:#6c7086">mk@kawashiro.dev — -zsh</div>
        <div class="w-14"></div>
      </div>

      <div class="p-5 leading-relaxed" style="color:#cdd6f4">
        <div>
          <span style="color:#a6e3a1">mk@kawashiro</span><span style="color:#6c7086">:</span><span
            style="color:#89b4fa">~</span><span style="color:#cba6f7"> $ </span>stat <span id="nf-path">this-page</span>
        </div>
        <div style="color:#f38ba8">stat: cannot stat: No such file or directory (404)</div>
        <div class="mt-3" style="color:#a6adc8">The route you requested does not exist on this edge node.</div>
        <div style="color:#a6adc8">La ruta que buscas no existe en este servidor.</div>
        <div style="color:#a6adc8">リクエストされたルートはこのサーバーに存在しません。</div>
        <div class="mt-4">
          <span style="color:#a6e3a1">mk@kawashiro</span><span style="color:#6c7086">:</span><span
            style="color:#89b4fa">~</span><span style="color:#cba6f7"> $ </span>
          <a href="/" class="underline decoration-dotted hover:opacity-80" style="color:#94e2d5">cd ~ (back home)</a>
          <span class="cursor-blink" aria-hidden="true">▌</span>
        </div>
      </div>
    </div>
  </main>

  <style>
    .cursor-blink {
      animation: blink404 1.1s steps(1) infinite;
      color: #cdd6f4;
    }
    @keyframes blink404 {
      50% { opacity: 0; }
    }
  </style>

  <script is:inline>
    // Refleja la ruta real que provocó el 404 en el "comando"
    const el = document.getElementById('nf-path');
    if (el) el.textContent = window.location.pathname;
  </script>
</Layout>
