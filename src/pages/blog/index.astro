---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="Blog | Mitsunori Kawashiro"
  description="Notes on self-hosting, data engineering and building things on a Raspberry Pi."
>
  <main class="min-h-screen w-full" style="color: var(--color-green500);">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 py-16">
      <a href="/" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">← Back</a>

      <h1 class="font-display font-semibold text-4xl sm:text-6xl tracking-tight mt-6 mb-4">Blog</h1>
      <p class="text-lg opacity-70 mb-14 max-w-xl">
        Notes on self-hosting, data engineering, and running production software on a Raspberry Pi.
      </p>

      <div class="flex flex-col gap-5">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-[32px] p-8 sm:p-10 transition-transform hover:-translate-y-1"
            style="background: var(--color-babyblue)"
          >
            <time class="text-[13px] font-semibold uppercase tracking-[0.2em] opacity-70">
              {post.data.pubDate.toISOString().slice(0, 10)}
            </time>
            <h2 class="font-display text-2xl sm:text-3xl font-semibold mt-1">{post.data.title}</h2>
            <p class="mt-2 text-base opacity-80 max-w-xl">{post.data.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-xs font-medium rounded-full px-3 py-1 bg-white/50">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
