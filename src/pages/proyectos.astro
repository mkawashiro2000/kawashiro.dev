---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/translations';

type Locale = 'en' | 'es' | 'ja';
type Project = {
  key: 'cajalocal' | 'kampit' | 'agrobalance' | 'lubesync' | 'tokenizer' | 'sentiment' | 'wordCounter';
  href: string;
  bg: string;
  /** Clave dentro de translations[loc].cards para la categoría traducida */
  categoryKey?: 'cajalocal' | 'kampit' | 'lubesync' | 'agrobalance';
};

// Orden: el primero del arreglo es el más reciente: los nuevos se añaden
// al principio de esta lista y los anteriores van bajando automáticamente.
const projects: Project[] = [
  { key: 'cajalocal', href: '/cajalocal', bg: 'var(--color-lilac)', categoryKey: 'cajalocal' },
  { key: 'kampit', href: '/proyectos/kampit', bg: 'var(--color-babyblue)', categoryKey: 'kampit' },
  { key: 'lubesync', href: '/proyectos/lubesyncrd', bg: 'var(--color-mint)', categoryKey: 'lubesync' },
  { key: 'agrobalance', href: '/proyectos/agrobalance', bg: 'var(--color-yellow)', categoryKey: 'agrobalance' },
  { key: 'tokenizer', href: '/proyectos/tokenizer-lemmatizador', bg: 'var(--color-babyblue)' },
  { key: 'sentiment', href: '/proyectos/detector-sentimientos', bg: 'var(--color-mint)' },
  { key: 'wordCounter', href: '/proyectos/contador-palabras', bg: 'var(--color-rust)' },
];

// Las categorías viven en translations[loc].cards.*; las herramientas de NLP
// comparten la del detector de sentimientos.
const categoriesFor = (loc: Locale) =>
  Object.fromEntries(
    projects.map((p) => [
      p.key,
      p.categoryKey
        ? translations[loc].cards[p.categoryKey].category
        : translations[loc].cards.sentiment.category,
    ]),
  );

const i18nData = {
  en: { back: translations.en.tools.back, ...translations.en.proyectos, categories: categoriesFor('en') },
  es: { back: translations.es.tools.back, ...translations.es.proyectos, categories: categoriesFor('es') },
  ja: { back: translations.ja.tools.back, ...translations.ja.proyectos, categories: categoriesFor('ja') },
};
const t = i18nData.en;
---

<Layout title="Projects | Mitsunori Kawashiro">
  <script type="application/json" id="i18n-data" set:html={JSON.stringify(i18nData)} />

  <main class="min-h-screen w-full" style="color: var(--color-green500);">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 py-16">
      <div class="flex items-center justify-between mb-2">
        <a href="/" data-i18n="back" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">{t.back}</a>
        <div class="lang-switcher">
          <button type="button" data-lang-btn="en" class="lang-pill">EN</button>
          <button type="button" data-lang-btn="es" class="lang-pill">ES</button>
          <button type="button" data-lang-btn="ja" class="lang-pill">JA</button>
        </div>
      </div>

      <h1 data-i18n="title" class="font-display font-semibold text-4xl sm:text-6xl tracking-tight mt-6 mb-4">
        {t.title}
      </h1>
      <p data-i18n="subtitle" class="text-lg opacity-70 mb-14 max-w-xl">
        {t.subtitle}
      </p>

      <div class="flex flex-col gap-5">
        {projects.map((p, i) => (
          <a
            href={p.href}
            class="group rounded-[32px] p-8 sm:p-10 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8 transition-transform hover:-translate-y-1"
            style={`background: ${p.bg}`}
          >
            {i === 0 && (
              <span data-i18n="mostRecent" class="sm:order-last shrink-0 text-xs font-semibold uppercase tracking-widest rounded-full px-3 py-1.5 bg-white/60 self-start sm:self-center">
                {t.mostRecent}
              </span>
            )}
            <div class="flex-1">
              <span data-i18n={`categories.${p.key}`} class="text-[13px] font-semibold uppercase tracking-[0.2em] opacity-70">
                {t.categories[p.key]}
              </span>
              <h2 data-i18n={`items.${p.key}.name`} class="font-display text-2xl sm:text-3xl font-semibold mt-1">
                {t.items[p.key].name}
              </h2>
              <p data-i18n={`items.${p.key}.desc`} class="mt-2 text-base opacity-80 max-w-xl">
                {t.items[p.key].desc}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <script src="/js/i18n.js" defer></script>
</Layout>
