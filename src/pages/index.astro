---
import Layout from '../layouts/Layout.astro';
import { PortfolioEcosystem } from '../components/shared/PortfolioEcosystem';
---

<Layout title="Mitsunori Kawashiro | Dev Ecosystem">
  <main className="min-h-screen flex flex-col items-center justify-center p-4 transition-colors duration-300">
    <div className="w-full max-w-4xl mb-6 text-center md:text-left flex flex-col md:flex-row md:items-end justify-between">
      <div>
        <h1 className="text-3xl font-bold tracking-tight mb-1">
          {/* Aplicación de CSS Puro para distorsión temporal de alta eficiencia */}
          <span className="glitch-text" data-text="kawashiro">kawashiro</span><span className="text-[var(--color-text-accent)]">.dev</span>
        </h1>
        <p className="text-sm text-[var(--color-text-muted)] mt-1 font-mono uppercase tracking-widest opacity-80">
          Dual-Mode Architecture // Zero Trust Edge
        </p>
      </div>
    </div>

    {/* Orquestador Cinemático y Lógico cargado en el cliente */}
    <PortfolioEcosystem client:load />
  </main>
</Layout>
