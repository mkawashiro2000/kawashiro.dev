const t = i18nData.en;
---

<Layout
  title="CajaLocal — Demo | Mitsunori Kawashiro"
  description="Interactive demo of CajaLocal: loan & collections management for micro-lending. Visual module tour and a fully working loan simulator."
>
  <script type="application/json" id="i18n-data" set:html={JSON.stringify(i18nData)} />

  <main id="main-content" class="min-h-screen w-full" style="color: var(--color-text-main);">
    <div class="max-w-4xl mx-auto px-6 sm:px-8 py-12">
      <div class="flex items-center justify-between mb-10">
        <a href="/proyectos" data-i18n="back" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">{t.back}</a>
        <div class="lang-switcher">
          <button type="button" data-lang-btn="en" class="lang-pill">EN</button>
          <button type="button" data-lang-btn="es" class="lang-pill">ES</button>
          <button type="button" data-lang-btn="ja" class="lang-pill">JA</button>
        </div>
      </div>

      {/* HERO */}
      <span
        data-i18n="badge"
        class="inline-flex items-center gap-2 text-[0.72rem] font-bold uppercase tracking-wider rounded-full px-3 py-1.5"
        style={`background: ${BLUE}1a; color: ${BLUE};`}
      >
        {t.badge}
      </span>
      <img src="/img/proyectos/cajalocal.webp" alt="CajaLocal" class="h-24 sm:h-28 w-auto object-contain object-left mt-6" />
      <p data-i18n="tagline" class="mt-6 text-2xl sm:text-3xl font-display font-semibold max-w-2xl leading-tight">{t.tagline}</p>
      <p data-i18n="intro" class="mt-4 text-lg opacity-75 max-w-3xl leading-relaxed">{t.intro}</p>

      {/* STATS */}
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-12">
        {t.stats.map((s, i) => (
          <div class="rounded-2xl p-5" style="background: var(--color-bg-secondary); border: 1px solid color-mix(in srgb, var(--color-text-muted) 18%, transparent);">
            <div class="text-3xl font-display font-bold" style={`color: ${BLUE}`} data-i18n={`stats.${i}.0`}>{s[0]}</div>
            <div class="text-sm opacity-70 mt-1" data-i18n={`stats.${i}.1`}>{s[1]}</div>
          </div>
        ))}
      </div>

      {/* MÓDULOS */}
      <h2 data-i18n="modulesTitle" class="font-display text-3xl font-semibold mt-16 mb-6">{t.modulesTitle}</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {t.modules.map((m, i) => (
          <div class="rounded-2xl p-6 transition-transform hover:-translate-y-1" style="background: var(--color-bg-secondary); border: 1px solid color-mix(in srgb, var(--color-text-muted) 18%, transparent);">
            <div class="text-3xl mb-3">{m[0]}</div>
            <h3 class="font-display text-xl font-semibold mb-1.5" data-i18n={`modules.${i}.1`}>{m[1]}</h3>
            <p class="text-sm opacity-75 leading-relaxed" data-i18n={`modules.${i}.2`}>{m[2]}</p>
          </div>
        ))}
      </div>

      {/* SIMULADOR (isla React funcional) */}
      <div class="mt-16 scroll-mt-8" id="simulador">
        <LoanSimulator client:visible />
      </div>

      {/* ARQUITECTURA */}
      <h2 data-i18n="archTitle" class="font-display text-3xl font-semibold mt-16 mb-3">{t.archTitle}</h2>
      <p data-i18n="archIntro" class="opacity-75 mb-5">{t.archIntro}</p>
      <ul class="flex flex-col gap-2.5">
        {t.arch.map((a, i) => (
          <li class="flex gap-3 items-start">
            <span class="shrink-0 mt-2 w-1.5 h-1.5 rounded-full" style={`background: ${BLUE}`}></span>
            <span class="opacity-85 font-mono text-sm" data-i18n={`arch.${i}`}>{a}</span>
          </li>
        ))}
      </ul>

      {/* HIGHLIGHTS TÉCNICOS */}
      <h2 data-i18n="techTitle" class="font-display text-3xl font-semibold mt-14 mb-5">{t.techTitle}</h2>
      <ul class="flex flex-col gap-3">
        {t.tech.map((x, i) => (
          <li class="flex gap-3 items-start">
            <span class="shrink-0 mt-1.5 w-2 h-2 rounded-full" style="background: var(--color-green500)"></span>
            <span class="opacity-85" data-i18n={`tech.${i}`}>{x}</span>
          </li>
        ))}
      </ul>

      {/* MODELO DE PRODUCTO */}
      <h2 data-i18n="productTitle" class="font-display text-3xl font-semibold mt-14 mb-5">{t.productTitle}</h2>
      <ul class="flex flex-col gap-3">
        {t.product.map((x, i) => (
          <li class="flex gap-3 items-start">
            <span class="shrink-0 mt-1.5 w-2 h-2 rounded-full" style="background: var(--color-green500)"></span>
            <span class="opacity-85" data-i18n={`product.${i}`}>{x}</span>
          </li>
        ))}
      </ul>

      {/* CTA */}
      <div class="mt-16 rounded-3xl p-8 sm:p-10 text-center" style={`background: ${NAVY};`}>
        <h2 data-i18n="ctaTitle" class="font-display text-2xl sm:text-3xl font-semibold" style="color: #ffffff;">{t.ctaTitle}</h2>
        <a
          href="https://wa.me/18299589614"
          target="_blank"
          rel="noreferrer"
          data-i18n="ctaBtn"
          class="inline-block mt-5 px-7 py-3 rounded-full font-semibold transition-transform hover:scale-105"
          style="background: #25D366; color: #0a3d1f;"
        >
          {t.ctaBtn}
        </a>
      </div>
    </div>
  </main>

  <script src="/js/i18n.js" defer></script>
</Layout>
