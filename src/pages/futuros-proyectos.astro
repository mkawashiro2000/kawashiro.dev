---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/translations';

type FutureProject = {
  key: 'cognitostrat' | 'foresightflow' | 'precisionag' | 'tempoprice';
  name: string;
  logo: string;
  bg: string;
};

const projects: FutureProject[] = [
  { key: 'cognitostrat', name: 'CognitoStrat', logo: '/img/proyectos/cognitostrat.png', bg: 'var(--color-babyblue)' },
  { key: 'foresightflow', name: 'ForesightFlow', logo: '/img/proyectos/foresightflow.png', bg: 'var(--color-yellow)' },
  { key: 'precisionag', name: 'PrecisionAg AI', logo: '/img/proyectos/precisionag-ai.png', bg: 'var(--color-mint)' },
  { key: 'tempoprice', name: 'TempoPrice', logo: '/img/proyectos/tempoprice.png', bg: 'var(--color-rust)' },
];

const i18nData = {
  en: { back: translations.en.tools.back, ...translations.en.futureProjects },
  es: { back: translations.es.tools.back, ...translations.es.futureProjects },
  ja: { back: translations.ja.tools.back, ...translations.ja.futureProjects },
};
const t = i18nData.en;
---

<Layout title="Future projects | Mitsunori Kawashiro">
  <script type="application/json" id="i18n-data" set:html={JSON.stringify(i18nData)} />

  <main class="min-h-screen w-full" style="color: var(--color-green500);">
    <div class="max-w-[1100px] mx-auto px-6 sm:px-8 py-16">
      <div class="flex items-center justify-between mb-2">
        <a href="/" data-i18n="back" class="text-sm font-medium opacity-60 hover:opacity-100 transition-opacity">{t.back}</a>
        <div class="lang-switcher">
          <button type="button" data-lang-btn="en" class="lang-pill">EN</button>
          <button type="button" data-lang-btn="es" class="lang-pill">ES</button>
          <button type="button" data-lang-btn="ja" class="lang-pill">JA</button>
        </div>
      </div>

      <h1 data-i18n="title" class="font-display font-semibold text-4xl sm:text-6xl tracking-tight mt-6 mb-4">
        {t.title}
      </h1>
      <p data-i18n="subtitle" class="text-lg opacity-70 mb-14 max-w-2xl">
        {t.subtitle}
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {projects.map((p) => (
          <div class="rounded-[32px] p-8 sm:p-10 flex flex-col" style={`background: ${p.bg}`}>
            <div class="flex items-start justify-between gap-4 mb-6">
              <img src={p.logo} alt={`${p.name} logo`} class="h-10 sm:h-12 w-auto object-contain object-left" />
              <span data-i18n="comingSoon" class="shrink-0 text-xs font-semibold uppercase tracking-widest rounded-full px-3 py-1.5 bg-white/60">
                {t.comingSoon}
              </span>
            </div>
            <p data-i18n={`items.${p.key}.tagline`} class="text-sm font-semibold uppercase tracking-widest opacity-70 mb-2">
              {t.items[p.key].tagline}
            </p>
            <p data-i18n={`items.${p.key}.desc`} class="text-base leading-relaxed opacity-85">
              {t.items[p.key].desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </main>

  <script src="/js/i18n.js" defer></script>
</Layout>
